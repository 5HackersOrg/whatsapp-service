<!doctype html>
<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SideGig Deposit</title>
    <style>
 

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      #txt {
        font-family: "Poppins", sans-serif;
      
      }
      body {
        padding: 30px;
        height: 100vh;
        display: flex;
        flex-direction: column;
      }
    </style>
  </head>
  <body>
    <h4 id="txt">WhatsHire</h1>
    <p id="txt" style="font-size: 11px; color: #656464;"> this link is only valid for 15 min</p>
<form action="/make-job-desposit" method="post">
    <p readonly id="txt" style="margin-top: 10px; font-size: 17px; background-color: transparent; border: none;" >hi <%= name %></p>
    <p id="txt" style="font-size: 12px;">your only one step away for your ad to be live </p>
    <p id="txt" style="font-size: 20px; font-weight: bold;">Side Gig Preview</p>
    <div style="display:  flex; gap: 25px; align-items: center;">
         <p id="txt" style="margin-top: 6px; font-weight: 500;">Title </p>
          <p readonly id="txt" name="title" style="margin-top: 6px; font-weight: 300;font-size: 16px; color: rgb(73, 73, 73); background-color: transparent; border: none;" ><%= gig.title %></p>
    </div>
    <div style="display:  flex; gap: 25px; align-items: center;">
         <p id="txt" style="margin-top: 6px; font-weight: 500;">Remote </p>
          <p id="txt" name="remote" style="margin-top: 6px; font-weight: 300;font-size: 16px; color: rgb(73, 73, 73); background-color: transparent; border: none;" ><%= gig.is_remote %></p>
    </div>
    <div style="display:  flex; gap: 2px;  flex-direction: column;">
         <p id="txt" style="margin-top: 6px; font-weight: 500;">Description </p>
          <p id="txt" name="description" style="margin-top: 6px; font-weight: 200;font-size: 16px; color: rgb(73, 73, 73); background-color: transparent; border: none; " ><%= gig.description %></p>
    </div>
    <div style="display:  flex; gap: 25px; align-items: center;">
         <p id="txt" style="margin-top: 6px; font-weight: 500;">Budget </p>
          <p id="txt" name="budget" style="margin-top: 6px; font-weight: 300;font-size: 16px; color: rgb(73, 73, 73); background-color: transparent; border: none; ">R<%= gig.budget %></p>
    </div>
     <div style="display:  flex; gap: 25px; align-items: center;">
         <p id="txt" style="margin-top: 6px; font-weight: 500;">Deposit </p>

          <p id="txt" name="deposit" style="margin-top: 6px; font-weight: 300;font-size: 16px; color: rgb(73, 73, 73); background-color: transparent; border: none;">R<%=deposit %></p>
    </div>
    <button  type="submit" style="width: 120px; padding: 5px; cursor: pointer;border-radius: 3px; margin-top: 20px; background-color: rgb(0, 0, 0); color: #ffffff;" id="txt" >Deposit</button>
   </form>
  </body>
</html>
